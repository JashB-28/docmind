# ── LLM & embedding backend ───────────────────────────────────────────────────
LLM_BACKEND=openai            # openai | ollama
EMBEDDING_BACKEND=openai      # openai | ollama

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Pinecone (vector database) ────────────────────────────────────────────────
# Create a free API key at https://app.pinecone.io
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_PREFIX=docmind
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Ollama (only when using the ollama backend) ───────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── API / sessions ────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for any (tighten this in production).
CORS_ORIGINS=*
# Minutes of inactivity before a session's vectors are auto-deleted.
SESSION_TTL_MINUTES=60
MAX_UPLOAD_MB=25
MAX_PAGES_PER_DOC=400

# ── Retrieval (Phase 3) ───────────────────────────────────────────────────────
# Rewrite conversational follow-ups into standalone queries before retrieval.
REWRITE_QUERIES=true
# RRF fusion of vector + BM25 rankings is always on. Tune the pool sizes:
VECTOR_TOP_K=10
BM25_TOP_K=10
RRF_K=60
FUSED_TOP_N=12
# Reranker: none | cohere | local. cohere/local need backend/requirements-rerank.txt
RERANKER=none
RERANK_TOP_N=5
# COHERE_API_KEY=...                      # required when RERANKER=cohere
# COHERE_RERANK_MODEL=rerank-english-v3.0
# LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # when RERANKER=local
