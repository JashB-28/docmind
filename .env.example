# ── LLM & embedding backend ───────────────────────────────────────────────────
LLM_BACKEND=openai            # openai | ollama
EMBEDDING_BACKEND=openai      # openai | ollama

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Pinecone (vector database) ────────────────────────────────────────────────
# Create a free API key at https://app.pinecone.io
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_PREFIX=docmind
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Ollama (only when using the ollama backend) ───────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Amazon Bedrock (only when using the bedrock provider) ──────────────────────
# Credentials come from the standard AWS chain — set AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY here, or attach an IAM role to the EC2 instance.
# Enable model access for these IDs in the Bedrock console for your region.
AWS_REGION=us-east-1
# Current Claude models need a cross-region inference profile id (us./global. prefix).
BEDROCK_LLM_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ── S3 (optional — ephemeral source-PDF storage) ──────────────────────────────
# Set S3_BUCKET to enable; blank = disabled. Uploaded PDFs are stored under
# S3_PREFIX/<session_id>/ and removed on clear/TTL (+ a bucket lifecycle rule).
S3_BUCKET=
S3_PREFIX=uploads
S3_URL_TTL_SECONDS=3600
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── API / sessions ────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for any (tighten this in production).
CORS_ORIGINS=*
# Minutes of inactivity before a session's vectors are auto-deleted.
SESSION_TTL_MINUTES=60
MAX_UPLOAD_MB=25
MAX_PAGES_PER_DOC=400

# ── Public deployment controls ────────────────────────────────────────────────
# Local dev: leave as-is. On the PUBLIC site set DEFAULT_PROVIDER=bedrock and
# ENABLE_OLLAMA=false (no Ollama server runs there).
DEFAULT_PROVIDER=openai
ENABLE_OLLAMA=true
# Abuse guards on the cost endpoints (per-IP window + site-wide daily cap):
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
DAILY_REQUEST_CAP=500

# ── Observability (Phase 4) ───────────────────────────────────────────────────
LOG_LEVEL=INFO
# Langfuse LLM tracing — optional. Leave blank to disable (structured logs still work).
# Get keys at https://cloud.langfuse.com (or self-host).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Retrieval (Phase 3) ───────────────────────────────────────────────────────
# Rewrite conversational follow-ups into standalone queries before retrieval.
REWRITE_QUERIES=true
# RRF fusion of vector + BM25 rankings is always on. Tune the pool sizes:
VECTOR_TOP_K=10
BM25_TOP_K=10
RRF_K=60
FUSED_TOP_N=12
# Reranker: none | cohere | local. cohere/local need backend/requirements-rerank.txt
RERANKER=none
RERANK_TOP_N=5
# COHERE_API_KEY=...                      # required when RERANKER=cohere
# COHERE_RERANK_MODEL=rerank-english-v3.0
# LOCAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # when RERANKER=local
